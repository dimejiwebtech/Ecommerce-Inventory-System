{
    "version": 2,
    "functions": {
        "InventoryMS/wsgi.py": {
            "runtime": "@vercel/python"
        }
    },
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/staticfiles/$1"
        },
        {
            "src": "/media/(.*)",
            "dest": "/media/$1"
        },
        {
            "src": "/(.*)",
            "dest": "InventoryMS/wsgi.py"
        }
    ]
}
